{
  "name": "reviewweb-cli",
  "version": "1.1.0",
  "description": "CLI tool for ReviewWeb.site API - create reviews, scrape websites, extract data, SEO insights and more",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "rws": "./bin/rws.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "reviewwebsite",
    "web-scraping",
    "seo",
    "ai",
    "markdown",
    "website-review",
    "api-client"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrgoonie/rws-cli"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "dependencies": {
    "adm-zip": "^0.5.17",
    "axios": "^1.7.9",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "form-data": "^4.0.5",
    "ora": "^8.2.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/form-data": "^2.2.1",
    "@types/node": "^22.15.3",
    "dotenv": "^17.2.3",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.0.9"
  }
}
